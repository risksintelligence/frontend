    "@types/d3": "^7.4.3",
    "@types/node": "20.9.0",
    "@types/react": "18.2.37",
    "@types/react-dom": "18.2.15",
    "autoprefixer": "10.4.16",
    "axios": "^1.12.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "0.7.0",
    "clsx": "2.0.0",
    "d3": "^7.8.5",
