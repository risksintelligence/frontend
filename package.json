    "react-dom": "18.2.0",
    "react-hook-form": "7.47.0",
    "react-plotly.js": "2.6.0",
    "react-query": "3.39.3",
    "recharts": "2.8.0",
    "serve": "^14.2.1",
    "swr": "2.2.4",
    "tailwind-merge": "2.0.0",
    "tailwindcss": "3.3.5",
